# PostgreSQL (Neon)
# DATABASE_URL: conexión pooled (-pooler) para la app en runtime
# DIRECT_URL: conexión directa (sin -pooler) para migraciones
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
PORT=3000
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
APP_URL="http://localhost:5173"

# Email (Gmail: usa una contraseña de aplicación, no tu contraseña normal)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu@gmail.com"
SMTP_PASS="contraseña-de-aplicacion"
MAIL_FROM="myWorkout <tu@gmail.com>"

# Google OAuth (Client ID público; mismo valor en VITE_GOOGLE_CLIENT_ID del client)
GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"

# --- Render (paso 3) ---
# Web Service → conectar repo → Blueprint render.yaml (o manual):
#   Build:  npm install && npm run build:prod --workspace=server && npm run migrate:deploy --workspace=server
#   Start:  npm run start:prod --workspace=server
#   Health: /api/health
# APP_URL en producción = URL de Vercel (paso 4), p. ej. https://myworkout.vercel.app
# Nota: uploads/ en Render es efímero; los avatares se pierden al redeploy.
