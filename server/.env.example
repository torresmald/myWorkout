# --- Local (Docker) — desarrollo y tests ---
# Arrancar: npm run db:up  →  docker compose up -d
DATABASE_URL="postgresql://myworkout:myworkout@localhost:5432/myworkout_dev"
DIRECT_URL="postgresql://myworkout:myworkout@localhost:5432/myworkout_dev"
TEST_DATABASE_URL="postgresql://myworkout:myworkout@localhost:5432/myworkout_test"

# --- Neon (producción) — no usar en local salvo que quieras apuntar a remoto ---
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

PORT=3000
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
APP_URL="http://localhost:5173"

# Email (Gmail: usa una contraseña de aplicación, no tu contraseña normal)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu@gmail.com"
SMTP_PASS="contraseña-de-aplicacion"
MAIL_FROM="myWorkout <tu@gmail.com>"

# Google OAuth (Client ID público; mismo valor en VITE_GOOGLE_CLIENT_ID del client)
GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"

# Spotify OAuth (Dashboard → https://developer.spotify.com/dashboard)
# Redirect URI en Spotify: http://localhost:3000/api/spotify/callback (dev)
# Producción: https://TU-API.onrender.com/api/spotify/callback
SPOTIFY_CLIENT_ID="tu-spotify-client-id"
SPOTIFY_CLIENT_SECRET="tu-spotify-client-secret"
SPOTIFY_REDIRECT_URI="http://localhost:3000/api/spotify/callback"

# Cloudinary (avatares) — cloud name en Dashboard → Account Details
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# Sentry (opcional — monitoring de errores en producción)
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Cron (recordatorios por email — Render Cron Job o similar)
# CRON_SECRET="long-random-secret"
# Llamar cada hora: POST /api/cron/workout-reminders con header X-Cron-Secret

# Primer admin (SQL en la BD local o Neon):
# UPDATE "User" SET role = 'ADMIN' WHERE email = 'tu@email.com';

# --- Render (producción) ---
# Build:  npm install --include=dev && npm run build:prod --workspace=server && npm run migrate:deploy --workspace=server
# Start:  npm run start:prod --workspace=server
# Health: /api/health
# APP_URL en producción = URL de Vercel, p. ej. https://myworkout.vercel.app
