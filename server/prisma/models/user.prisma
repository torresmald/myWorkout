enum Role {
  USER
  ADMIN
}

model User {
  id               Int            @id @default(autoincrement())
  email            String         @unique
  password         String
  name             String?
  role             Role           @default(USER)
  refreshTokenHash String?        @unique
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  exerciseTypes    ExerciseType[]
}
