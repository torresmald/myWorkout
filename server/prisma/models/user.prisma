enum Role {
  USER
  ADMIN
}

model User {
  id                      Int                       @id @default(autoincrement())
  email                   String                    @unique
  password                String?
  googleId                String?                   @unique
  name                    String?
  locale                  String                    @default("es")
  heightCm                Decimal?                  @db.Decimal(5, 2)
  profileImagePath        String?
  role                    Role                      @default(USER)
  refreshTokenHash        String?                   @unique
  emailVerifiedAt         DateTime?
  lastLoginAt             DateTime?
  pushReminderEnabled     Boolean                   @default(false)
  emailReminderEnabled    Boolean                   @default(false)
  reminderDays            Int[]                     @default([])
  reminderTimeLocal       String                    @default("18:00")
  reminderTimezone        String                    @default("UTC")
  lastEmailReminderSentAt DateTime?
  spotifyPlaylistUrl      String?
  spotifyUserId           String?                   @unique
  spotifyAccessToken      String?
  spotifyRefreshToken     String?
  spotifyTokenExpiresAt   DateTime?
  spotifyDisplayName      String?
  spotifyPlaylistName     String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  exerciseTypes           ExerciseType[]
  workouts                Workout[]
  workoutTemplates        WorkoutTemplate[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  weightEntries           WeightEntry[]
}
