model ExerciseType {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  description String?
  muscleGroup String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  workoutExercises WorkoutExercise[]

  @@unique([userId, name])
}
