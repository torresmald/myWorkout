{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:prod": "prisma generate --schema=prisma && tsc",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "migrate": "prisma migrate dev --schema=prisma",
    "migrate:deploy": "prisma migrate deploy --schema=prisma",
    "studio": "prisma studio --schema=prisma",
    "generate": "prisma generate --schema=prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.55.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "prisma": "6.19.3",
    "typescript": "~5.8.3"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
