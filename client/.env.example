# Mismo Client ID que GOOGLE_CLIENT_ID en server/.env
VITE_GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"

# Sentry (opcional — mismo proyecto que server, DSN del SDK browser)
VITE_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# --- Vercel (paso 4) ---
# Root Directory en Vercel: client
# Añade VITE_GOOGLE_CLIENT_ID en el dashboard de Vercel (Environment Variables).
